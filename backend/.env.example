GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

MODEL_PROVIDER=gemini
MODEL_NAME=gemini-1.5-flash
MODEL_TIMEOUT_SECONDS=30
MOCK_MODEL_WHEN_MISSING_KEY=true

# Backward compatibility
GEMMA_MODEL=gemini-1.5-flash
GEMMA_FALLBACK_MODELS=gemini-1.5-flash
GEMMA_TIMEOUT_SECONDS=30
MOCK_GEMMA_WHEN_MISSING_KEY=true

CORS_ORIGINS=http://localhost:5173
GOOGLE_CLOUD_PROJECT=
NEES_TRACE_TARGET=local
NEES_CLOUD_RUN_TARGET=planned
